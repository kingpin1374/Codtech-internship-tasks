pipeline {
    agent any

    environment {
        APP_NAME = 'webbook'
        APP_PORT = '9000'
        // Prevents Jenkins from killing the Flask app process when the job finishes
        JENKINS_NODE_COOKIE = 'dontKillMe'
    }

    triggers {
        githubPush()
    }

    stages {
        stage('Checkout') {
            steps {
                // Jenkins usually does this automatically, but keeping it as per your requirement
                git branch: 'master', 
                    url: 'https://github.com/kingpin1374/Codtech-internship-tasks.git', 
                    credentialsId: 'github'
            }
        }

        stage('Setup & Install') {
            steps {
                sh '''
                    python3 -m venv venv
                    ./venv/bin/pip install --upgrade pip
                    ./venv/bin/pip install flask
                    if [ -f requirements.txt ]; then
                        ./venv/bin/pip install -r requirements.txt
                    fi
                '''
            }
        }

        stage('Build and Deploy') {
            steps {
                sh '''
                    # Navigate to the folder where app.py is located
                    cd task2
                    
                    # Kill any existing process on port 9000 to avoid 'Port already in use' errors
                    fuser -k ${APP_PORT}/tcp || true
                    
                    # Run the app in the background using nohup
                    # We use the venv python to ensure Flask is found
                    nohup ../venv/bin/python app.py --port=${APP_PORT} > app.log 2>&1 &
                    
                    # Give it a few seconds to initialize
                    sleep 5
                    echo "Application is deploying on port ${APP_PORT}"
                '''
            }
        }
    }
}
