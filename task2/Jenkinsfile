pipeline{
  agent any

  environment{
    APP_NAME = 'webbook'
    APP_PORT = '9000'
  }

  triggers {
    githubPush()
  }
  stages{
    stage ('copy repo'){
      steps {
        git branch: 'master', url: 'https://github.com/kingpin1374/Codtech-internship-tasks.git', credentialsId: 'github'
      }
    }

    stage ('install venv') {
      steps{
      sh 'sudo apt install python3-venv -y'
     }
   }
    stage ('activate the env') {
      steps{
        sh 'python3 -m venv venv'
      }
    }
    stage ('activate venv') {
      steps {
        sh './venv/bin/pip install flask'
        }
    }
    stage ('install requirements') {
      steps {
        sh 'pip install requirement.txt'
      }
    }
    stage ('build and deploy') {
      steps {
        sh 'python3 app.py'
      }
    }
  }
  
}
