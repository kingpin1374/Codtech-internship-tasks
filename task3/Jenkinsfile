pipeline {
    agent any

    triggers {
        githubPush()
    }

    stages {
        stage('Cloning Repo') {
            steps {
                // Jenkins usually does this automatically, but keeping it as per your requirement
                git branch: 'master', 
                    url: 'https://github.com/kingpin1374/Codtech-internship-tasks.git', 
                    credentialsId: 'github'
            }
        }

        stage('Setup Environment') {
            steps {
                script {
                    echo "Checking for Kind cluster..."
                    // Single quotes here prevent the dollar-sign compilation error
                    def clusterStatus = sh(script: 'kind get clusters | grep -q "^kind$"', returnStatus: true)
                    
                    if (clusterStatus != 0) {
                        echo "Cluster not found. Creating Kind cluster..."
                        sh "kind create cluster --name kind"
                    } else {
                        echo "Kind cluster is already running. Proceeding..."
                    }
                }
            }
        }

        stage('Build Image') {
            steps {
                echo "Building Docker image..."
                // Using the specific paths you provided
                sh "docker build -t uniform-wala:local -f task3/Dockerfile task3/"
            }
        }

        stage('Load into Kind') {
            steps {
                echo "Loading image into Kind..."
                sh "kind load docker-image uniform-wala:local --name kind"
            }
        }

        stage('Deploy') {
            steps {
                script {
                    echo "Deploying to Kubernetes..."
                    dir('task3') {
                        sh 'kubectl apply -f deployment.yaml'
                        sh 'kubectl apply -f service.yaml'
                        sh 'kubectl rollout status deployment/uniform-wala-app'
                    }
                }
            }
        }
    } // End of Stages

    post {
        success {
            echo "Successfully deployed Uniform Wala to Kind Cluster!"
        }
        failure {
            echo "Build failed. Check the logs for errors."
        }
    }
} // End of Pipeline
