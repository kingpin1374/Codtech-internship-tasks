pipeline {
    agent any

    stages {
        stage('Environment Prep') {
            steps {
                echo "Reclaiming disk space before starting..."
                sh "docker system prune -f"
            }
        }

        stage('Cloning Repo') {
            steps {
                git branch: 'master', url: 'https://github.com/kingpin1374/Codtech-internship-tasks.git'
            }
        }

        stage('Build & Load') {
            steps {
                sh "docker build -t uniform-wala:local -f task4/Dockerfile task4/"
                sh "kind load docker-image uniform-wala:local --name kind"
            }
        }

        stage('Deploy') {
            steps {
                dir('task4') {
                    sh "kubectl apply -f deployment.yml || kubectl apply -f deployment.yaml"
                    sh "kubectl apply -f service.yml || kubectl apply -f service.yaml"
                    sh "kubectl rollout status deployment/uniform-wala-app"
                }
            }
        }

        stage('OWASP ZAP Scan') {
            steps {
                script {
                    echo "Starting Security Scan (DAST)..."
                    // We use '|| true' so that even if ZAP hits a disk error, 
                    // the pipeline can still finish and archive the report.
                    sh """
                    docker run --rm --user root \
                        --network=host \
                        -v ${WORKSPACE}:/zap/wrk/:rw \
                        -t ghcr.io/zaproxy/zaproxy:stable zap-baseline.py \
                        -t http://127.0.0.1:8081 \
                        -r zap_report.html || true
                    """
                }
            }
        }
    }

    post {
        always {
            echo "Archiving artifacts..."
            archiveArtifacts artifacts: '**/zap_report.html', allowEmptyArchive: true
        }
    }
}
