pipeline {
    agent any

    stages {
        stage('Cleanup Environment') {
            steps {
                echo "Cleaning up old docker layers to save space..."
                // This removes unused data so the ZAP image has room to download
                sh "docker system prune -f"
            }
        }

        stage('Cloning Repo') {
            steps {
                git branch: 'master', url: 'https://github.com/kingpin1374/Codtech-internship-tasks.git'
            }
        }

        stage('Build & Load') {
            steps {
                sh "docker build -t uniform-wala:local -f task4/Dockerfile task4/"
                sh "kind load docker-image uniform-wala:local --name kind"
            }
        }

        stage('Deploy') {
            steps {
                // Ensure the directory matches where your YAMLs are stored
                dir('task3') {
                    sh 'kubectl apply -f deployment.yml'
                    sh 'kubectl apply -f service.yml'
                    sh 'kubectl rollout status deployment/uniform-wala-app'
                }
            }
        }

        stage('OWASP ZAP Scan') {
            steps {
                script {
                    echo "Starting Dynamic Security Scan (DAST)..."
                    // Added --user root to prevent permission issues inside the workspace
                    sh """
                    docker run --rm --user root \
                        --network=host \
                        -v ${WORKSPACE}:/zap/wrk/:rw \
                        -t ghcr.io/zaproxy/zaproxy:stable zap-baseline.py \
                        -t http://127.0.0.1:8081 \
                        -r zap_report.html || true
                    """
                }
            }
        }
    }

    post {
        always {
            echo "Pipeline finished. Saving the security report..."
            // allowEmptyArchive: true prevents the build from failing if ZAP crashes mid-scan
            archiveArtifacts artifacts: 'zap_report.html', fingerprint: true, allowEmptyArchive: true
        }
    }
}
