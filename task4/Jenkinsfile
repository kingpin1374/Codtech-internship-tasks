pipeline {
    agent any

    environment {
        SONAR_SERVER = 'SonarQube-Server'
    }

    stages {
        stage('Cloning Repo') {
            steps {
                git branch: 'master', url: 'https://github.com/kingpin1374/Codtech-internship-tasks.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script {
                    def scannerHome = tool 'SonarQubeScanner'
                    withSonarQubeEnv("${SONAR_SERVER}") {
                        sh "${scannerHome}/bin/sonar-scanner \
                            -Dsonar.projectKey=UniformWala \
                            -Dsonar.sources=task3/ \
                            -Dsonar.host.url=http://your-sonarqube-ip:9000"
                    }
                }
            }
        }

        stage('Build & Load') {
            steps {
                sh "docker build -t uniform-wala:local -f task3/Dockerfile task3/"
                sh "kind load docker-image uniform-wala:local --name kind"
            }
        }

        stage('Deploy') {
            steps {
                dir('task3') {
                    sh 'kubectl apply -f deployment.yaml'
                    sh 'kubectl apply -f service.yaml'
                    sh 'kubectl rollout status deployment/uniform-wala-app'
                }
            }
        }

        stage('OWASP ZAP Scan') {
            steps {
                script {
                    echo "Starting Dynamic Security Scan..."
                    // Replace <YOUR_EC2_IP> with your actual public IP address
                    sh "docker run --rm -v ${WORKSPACE}:/zap/wrk/:rw -t ghcr.io/zaproxy/zaproxy:stable zap-baseline.py \
                        -t http://<YOUR_EC2_IP>:8081 -r zap_report.html || true"
                }
            }
        }
    } // <-- Ends stages

    post { // <-- post is a sibling to stages, both inside pipeline
        always {
            echo "Archiving security artifacts..."
            archiveArtifacts artifacts: 'zap_report.html', fingerprint: true
        }
    }
} // <-- Ends pipeline
